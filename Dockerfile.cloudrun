# Use PyTorch's official CUDA image — it already has
# Python 3.11, CUDA, and all GPU drivers preinstalled
# Much more reliable than building from nvidia/cuda base
FROM pytorch/pytorch:2.3.0-cuda12.1-cudnn8-runtime

ENV DEBIAN_FRONTEND=noninteractive

# System dependencies
RUN apt-get update && apt-get install -y \
    ffmpeg \
    git \
    build-essential \
    curl \
    ca-certificates \
    sox \
    libsox-fmt-all \
    && rm -rf /var/lib/apt/lists/*

# Install gcloud SDK for gsutil (to download model from GCS)
RUN curl -sSL https://sdk.cloud.google.com | bash -s -- \
    --disable-prompts \
    --install-dir=/usr/local
ENV PATH=$PATH:/usr/local/google-cloud-sdk/bin

WORKDIR /app
COPY . .

# Install Python dependencies
RUN pip install --no-cache-dir \
    "huggingface_hub[cli]>=0.23.0" \
    "hf_transfer" \
    && pip install --no-cache-dir -e ".[api]"

# Try flash attention — skip if it fails
RUN pip install flash-attn --no-build-isolation \
    || echo "⚠️ flash-attn skipped — will use sdpa instead"

# ─────────────────────────────────────────────
# Environment
# ─────────────────────────────────────────────
ENV TTS_BACKEND=official
ENV TTS_MODEL_ID=Qwen/Qwen3-TTS-12Hz-1.7B-VoiceDesign
ENV TTS_MODEL_NAME=Qwen/Qwen3-TTS-12Hz-1.7B-VoiceDesign
ENV TTS_DEVICE=cuda
ENV TTS_DTYPE=bfloat16
ENV TTS_ATTN=sdpa
ENV TTS_WARMUP_ON_START=false
ENV TTS_MAX_CONCURRENT=1
ENV WORKERS=1
ENV HOST=0.0.0.0
ENV PORT=8080
ENV IDLE_SHUTDOWN_TIMEOUT=0
ENV MODEL_LOCAL_DIR=/tmp/model-cache/Qwen3-TTS-12Hz-1.7B-VoiceDesign
ENV HF_HOME=/tmp/hf-cache
ENV GCS_MODEL_BUCKET=qwen3-tts-model-cache
ENV GCS_MODEL_PATH=Qwen3-TTS-12Hz-1.7B-VoiceDesign

COPY start-cloudrun.sh /app/start-cloudrun.sh
RUN chmod +x /app/start-cloudrun.sh

EXPOSE 8080
CMD ["/app/start-cloudrun.sh"]
