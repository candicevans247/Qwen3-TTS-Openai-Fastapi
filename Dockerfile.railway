# Dockerfile.railway
FROM python:3.12-slim

RUN apt-get update && apt-get install -y \
    ffmpeg \
    git \
    build-essential \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY . .

RUN pip install --no-cache-dir \
    "huggingface_hub[cli]>=0.23.0" \
    "hf_transfer" \
    && pip install --no-cache-dir -e ".[api]"

ENV TTS_BACKEND=pytorch
ENV TTS_MODEL_ID=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice
ENV TTS_DEVICE=cpu
ENV TTS_DTYPE=float32
ENV TTS_ATTN=sdpa
ENV CPU_THREADS=4
ENV CPU_INTEROP=1
ENV OMP_NUM_THREADS=4
ENV MKL_NUM_THREADS=4
ENV TTS_WARMUP_ON_START=false
ENV TTS_MAX_CONCURRENT=1
ENV WORKERS=1
ENV HOST=0.0.0.0
ENV PORT=8880
ENV HF_HOME=/model-cache
ENV HUGGINGFACE_HUB_CACHE=/model-cache

COPY start.sh /app/start.sh
RUN chmod +x /app/start.sh

EXPOSE 8880

HEALTHCHECK \
    --interval=30s \
    --timeout=10s \
    --start-period=300s \
    --retries=5 \
    CMD python -c \
    "import urllib.request; urllib.request.urlopen('http://localhost:8880/health')" \
    || exit 1

CMD ["/app/start.sh"]
